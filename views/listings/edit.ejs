<% layout('layouts/boilerplate') -%>
<section class="listing-form-shell">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="listing-form-card">
                <div class="listing-form-header">
                    <p class="listing-form-kicker">Update listing</p>
                    <h1>Edit Listing</h1>
                    <p class="listing-form-subtitle">Refine the details travelers will see before your listing goes live.</p>
                </div>
                <form action="/listings/<%= listing._id %>?_method=PUT" method="POST" class="listing-form">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" id="title" name="listing[title]" value="<%= listing.title %>" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea id="description" name="listing[description]" class="form-control listing-description" required><%= listing.description %></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="imageUrl" class="form-label">Image URL</label>
                        <input type="text" id="imageUrl" name="listing[image][url]" value="<%= listing.image ? listing.image.url : '' %>" class="form-control">
                    </div>
                    <div class="row g-3">
                        <div class="mb-3 col-md-4">
                            <label for="price" class="form-label">Price</label>
                            <input type="number" id="price" name="listing[price]" step="0.01" value="<%= listing.price %>" class="form-control" required>
                        </div>
                        <div class="mb-3 col-md-8">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" id="country" name="listing[country]" value="<%= listing.country %>" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" id="location" name="listing[location]" value="<%= listing.location %>" class="form-control" required>
                    </div>

                    <div class="listing-form-actions">
                        <button type="submit" class="btn btn-dark add-btn listing-submit-btn">Update Listing</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>