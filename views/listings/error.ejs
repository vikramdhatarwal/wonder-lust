<% layout('layouts/boilerplate') -%>

<section class="error-shell">
    <div class="error-card" role="alert" aria-live="polite">
        <div class="error-icon-wrap" aria-hidden="true">
            <% if (err.statusCode === 404) { %>
                <i class="fa-regular fa-map"></i>
            <% } else if (err.statusCode === 400) { %>
                <i class="fa-solid fa-circle-info"></i>
            <% } else { %>
                <i class="fa-solid fa-screwdriver-wrench"></i>
            <% } %>
        </div>

        <p class="error-kicker">Error <%= err.statusCode || 500 %></p>
        <h1><%= err.title || "Something went wrong" %></h1>
        <p class="error-message"><%= err.message || "An unexpected problem occurred. Please try again in a moment." %></p>

        <div class="error-actions">
            <a href="/listings" class="btn btn-dark add-btn error-primary-action">
                <i class="fa-solid fa-magnifying-glass"></i>
                Browse listings
            </a>
            <button type="button" class="btn btn-outline-dark error-secondary-action" onclick="history.back()">
                <i class="fa-solid fa-arrow-left"></i>
                Go back
            </button>
        </div>
    </div>
</section>
