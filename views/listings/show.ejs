<% layout('layouts/boilerplate') -%>

<section class="listing-show-shell">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-9">
            <div class="listing-show-card">
                <div class="listing-show-media">
                    <% if (listing.image) { %>
                        <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-show-image">
                    <% } else { %>
                        <div class="listing-show-placeholder">
                            <i class="fa-solid fa-image"></i>
                            <span>No image available</span>
                        </div>
                    <% } %>
                </div>

                <div class="listing-show-content">
                    <div class="listing-show-header">
                        <p class="listing-show-kicker">Stay details</p>
                        <h1><%= listing.title %></h1>
                        <div class="listing-show-badges">
                            <span class="listing-show-badge"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></span>
                            <span class="listing-show-badge"><i class="fa-solid fa-globe"></i> <%= listing.country %></span>
                        </div>
                    </div>

                    <div class="listing-show-price-wrap">
                        <span class="listing-show-price-label">Price per night</span>
                        <span class="listing-show-price">
                            <% if (listing.price != null) { %>
                                &#8377; <%= listing.price.toLocaleString('en-IN') %>/night
                            <% } else { %>
                                Price unavailable
                            <% } %>
                        </span>
                    </div>

                    <% const isListingOwner = currentUser && listing.owner && currentUser._id.equals(listing.owner._id || listing.owner); %>

                    <div class="listing-show-description">
                        <h2>Description</h2>
                        <p><%= listing.description %></p>
                    </div>
                        <% if(isListingOwner) { %>
                            <div class="listing-show-actions">
                                <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark listing-action-btn">Edit Listing</a>
                                <form action="/listings/<%= listing._id %>/delete" method="get" class="listing-delete-form">
                                    <button type="submit" class="btn btn-dark add-btn listing-submit-btn listing-delete-btn">Delete Listing</button>
                                </form>
                            </div>
                        <% } %>

                    
                    <div class="listing-show-divider"></div>

                    <div class="listing-reviews-section">
                        <% if (currentUser) { %>
                            <div class="listing-review-form-card">
                                <div class="listing-section-header">
                                    <p class="listing-show-kicker">Guest feedback</p>
                                    <h2>Leave a review</h2>
                                </div>
                                
                                <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="listing-review-form needs-validation">
                                    <div class="mb-3">
                                        <label for="rating" class="form-label">Rating</label>
                                        <fieldset class="starability-slot">                                        
                                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="1" checked aria-label="No rating." />
                                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                                            <label for="first-rate1" title="Terrible">1 star</label>
                                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                                            <label for="first-rate2" title="Not good">2 stars</label>
                                            <input type="radio" id="first-rate3" name="review[rating]" value="3" />
                                            <label for="first-rate3" title="Average">3 stars</label>
                                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                                            <label for="first-rate4" title="Very good">4 stars</label>
                                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                                            <label for="first-rate5" title="Amazing">5 stars</label>
                                        </fieldset>
                                    </div>                        
                                    <div class="mb-3">
                                        <label for="comment" class="form-label">Comment</label>
                                        <textarea class="form-control" id="comment" name="review[comment]" rows="4" placeholder="Share what stood out about this stay" required></textarea>
                                        <div class="invalid-feedback">
                                            Please provide a comment.
                                        </div>
                                    </div>
                                    <button type="submit" class="btn btn-dark add-btn listing-submit-btn listing-review-submit">Submit Review</button>
                                </form>
                            </div>
                        <% } %>
                        <div class="listing-section-header listing-reviews-heading">
                            <p class="listing-show-kicker">Reviews</p>
                            <h2>What guests are saying</h2>
                        </div>
                        <% if (listing.reviews.length === 0) { %>
                            <div class="listing-empty-reviews">
                                <i class="fa-regular fa-message"></i>
                                <p>No reviews yet. Be the first to share your experience.</p>
                            </div>
                        <% } else { %>
                            <div class="listing-review-grid">
                                <% listing.reviews.forEach(review => { %>
                                    <% 
                                        const author = review.author;
                                        const authorId = author && (author._id || author);
                                        const authorName = author && author.username ? author.username : "Deleted user";
                                        const authorInitials = authorName
                                            .split(" ")
                                            .map(name => name[0])
                                            .join("")
                                            .slice(0, 2)
                                            .toUpperCase();
                                        const isReviewOwner = currentUser && authorId && currentUser._id.equals(authorId);
                                    %>
                                    <div class="listing-review-card">
                                        <div class="listing-review-card-head">
                                            <div class="listing-review-avatar"><%= authorInitials %></div>
                                            <div>
                                                <h3><%= authorName %></h3>
                                                <p><i class="fa-solid fa-star"></i> <%= review.rating %> / 5</p>
                                            </div>
                                        </div>
                                        <p class="listing-review-comment"><%= review.comment %></p>
                                        <% if(isReviewOwner) { %>
                                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post" class="listing-review-delete-form">
                                                <button type="submit" class="btn btn-sm btn-outline-dark listing-review-delete-btn">Delete</button>
                                            </form>
                                        <% } %>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>
                        
                    </div>
                    <hr>
                    <%# Map section: geocodes the listing address and routes from the visitor's browser location. %>
                    <div class="listing-map-section">
                        <div class="listing-map-container">
                            <div class="listing-map-heading">
                                <div>
                                    <p class="listing-show-kicker">Location</p>
                                    <h3>Where you'll be</h3>
                                </div>
                                <span class="listing-map-address"><i class="fa-solid fa-location-dot"></i> <%= listing.location %>, <%= listing.country %></span>
                            </div>
                            <div class="listing-route-controls">
                                <button type="button" id="goToListingBtn" class="btn btn-dark add-btn" disabled>
                                    <i class="fa-solid fa-route"></i> Go
                                </button>
                                <span id="routeStatus" class="text-muted fw-semibold">Finding destination...</span>
                            </div>
                            <div id="map"></div>
                            <p id="mapFallback" class="text-muted fw-semibold mt-2 d-none"></p>
                            
                        </div>  
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://cdn.maptiler.com/maptiler-sdk-js/latest/maptiler-sdk.umd.min.js"></script>
<script>
    // Safely expose only the data the browser-side map needs.
    window.listingMapData = {
        mapToken: <%- JSON.stringify(mapToken || "").replace(/</g, "\\u003c") %>,
        listingTitle: <%- JSON.stringify(listing.title).replace(/</g, "\\u003c") %>,
        listingAddress: <%- JSON.stringify(`${listing.location}, ${listing.country}`).replace(/</g, "\\u003c") %>,
        listingCoordinates: <%- JSON.stringify(listing.geometry && listing.geometry.coordinates ? listing.geometry.coordinates : null).replace(/</g, "\\u003c") %>
    };
</script>
<script src="/js/map.js"></script>
