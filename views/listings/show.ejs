<% layout('layouts/boilerplate') -%>

<section class="listing-show-shell">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-9">
            <div class="listing-show-card">
                <div class="listing-show-media">
                    <% if (listing.image) { %>
                        <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-show-image">
                    <% } else { %>
                        <div class="listing-show-placeholder">
                            <i class="fa-solid fa-image"></i>
                            <span>No image available</span>
                        </div>
                    <% } %>
                </div>

                <div class="listing-show-content">
                    <div class="listing-show-header">
                        <p class="listing-show-kicker">Stay details</p>
                        <h1><%= listing.title %></h1>
                        <div class="listing-show-badges">
                            <span class="listing-show-badge"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></span>
                            <span class="listing-show-badge"><i class="fa-solid fa-globe"></i> <%= listing.country %></span>
                        </div>
                    </div>

                    <div class="listing-show-price-wrap">
                        <span class="listing-show-price-label">Price per night</span>
                        <span class="listing-show-price">
                            <% if (listing.price != null) { %>
                                &#8377; <%= listing.price.toLocaleString('en-IN') %>/night
                            <% } else { %>
                                Price unavailable
                            <% } %>
                        </span>
                    </div>

                    <div class="listing-show-description">
                        <h2>Description</h2>
                        <p><%= listing.description %></p>
                    </div>
                        <% if(currentUser && currentUser._id.equals(listing.owner)) { %>
                            <div class="listing-show-actions">
                                <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark listing-action-btn">Edit Listing</a>
                                <form action="/listings/<%= listing._id %>/delete" method="get" class="listing-delete-form">
                                    <button type="submit" class="btn btn-dark add-btn listing-submit-btn listing-delete-btn">Delete Listing</button>
                                </form>
                            </div>
                        <% } %>

                    
                    <div class="listing-show-divider"></div>

                    <div class="listing-reviews-section">
                        <div class="listing-review-form-card">
                            <div class="listing-section-header">
                                <p class="listing-show-kicker">Guest feedback</p>
                                <h2>Leave a review</h2>
                            </div>
                            <form action="/listings/<%= listing._id %>/reviews" method="post" novalidate class="listing-review-form needs-validation">
                                <div class="mb-3">
                                    <label for="rating" class="form-label">Rating</label>
                                    <div class="listing-rating-control">
                                        <span>1</span>
                                        <input type="range" min="1" max="5" id="rating" class="form-range" name="review[rating]" required>
                                        <span>5</span>
                                    </div>
                                </div>
                                <div class="mb-3">
                                    <label for="comment" class="form-label">Comment</label>
                                    <textarea class="form-control" id="comment" name="review[comment]" rows="4" placeholder="Share what stood out about this stay" required></textarea>
                                    <div class="invalid-feedback">
                                        Please provide a comment.
                                    </div>
                                </div>
                                <button type="submit" class="btn btn-dark add-btn listing-submit-btn listing-review-submit">Submit Review</button>
                            </form>
                        </div>

                        <div class="listing-section-header listing-reviews-heading">
                            <p class="listing-show-kicker">Reviews</p>
                            <h2>What guests are saying</h2>
                        </div>
                        <% if (listing.reviews.length === 0) { %>
                            <div class="listing-empty-reviews">
                                <i class="fa-regular fa-message"></i>
                                <p>No reviews yet. Be the first to share your experience.</p>
                            </div>
                        <% } else { %>
                            <div class="listing-review-grid">
                                <% listing.reviews.forEach(review => { %>
                                    <div class="listing-review-card">
                                        <div class="listing-review-card-head">
                                            <div class="listing-review-avatar">JD</div>
                                            <div>
                                                <h3>Jan Doe</h3>
                                                <p><i class="fa-solid fa-star"></i> <%= review.rating %> / 5</p>
                                            </div>
                                        </div>
                                        <p class="listing-review-comment"><%= review.comment %></p>
                                        <% if(currentUser && review.author && currentUser._id.equals(review.author)) { %>
                                            <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" method="post" class="listing-review-delete-form">
                                                <button type="submit" class="btn btn-sm btn-outline-dark listing-review-delete-btn">Delete</button>
                                            </form>
                                        <% } %>
                                    </div>
                                <% }); %>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
