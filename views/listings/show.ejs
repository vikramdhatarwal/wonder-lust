<% layout('layouts/boilerplate') -%>
<section class="listing-show-shell">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-10 col-xl-9">
            <div class="listing-show-card">
                <div class="listing-show-media">
                    <% if (listing.image) { %>
                        <img src="<%= listing.image.url %>" alt="<%= listing.title %>" class="listing-show-image">
                    <% } else { %>
                        <div class="listing-show-placeholder">
                            <i class="fa-solid fa-image"></i>
                            <span>No image available</span>
                        </div>
                    <% } %>
                </div>

                <div class="listing-show-content">
                    <div class="listing-show-header">
                        <p class="listing-show-kicker">Stay details</p>
                        <h1><%= listing.title %></h1>
                        <div class="listing-show-badges">
                            <span class="listing-show-badge"><i class="fa-solid fa-location-dot"></i> <%= listing.location %></span>
                            <span class="listing-show-badge"><i class="fa-solid fa-globe"></i> <%= listing.country %></span>
                        </div>
                    </div>

                    <div class="listing-show-price-wrap">
                        <span class="listing-show-price-label">Price per night</span>
                        <span class="listing-show-price">&#8377 <%= listing.price.toLocaleString('en-IN') %></span>
                    </div>

                    <div class="listing-show-description">
                        <h2>Description</h2>
                        <p><%= listing.description %></p>
                    </div>

                    <div class="listing-show-actions">
                        <a href="/listings/<%= listing._id %>/edit" class="btn btn-outline-dark listing-action-btn">Edit Listing</a>
                        <form action="/listings/<%= listing._id %>/delete" method="get" class="listing-delete-form">
                            <button type="submit" class="btn btn-dark add-btn listing-action-btn listing-delete-btn">Delete Listing</button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>