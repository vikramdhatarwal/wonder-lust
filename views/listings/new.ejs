<% layout('layouts/boilerplate') -%>
<section class="listing-form-shell">
    <div class="row justify-content-center">
        <div class="col-12 col-lg-8">
            <div class="listing-form-card">
                <div class="listing-form-header">
                    <p class="listing-form-kicker">Host a new stay</p>
                    <h1>Create New Listing</h1>
                    <p class="listing-form-subtitle">Add the details travelers need to discover your place quickly.</p>
                </div>
                <form action="/listings" method="POST" class="listing-form">
                    <div class="mb-3">
                        <label for="title" class="form-label">Title</label>
                        <input type="text" id="title" name="listing[title]" placeholder="Enter title" class="form-control" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label">Description</label>
                        <textarea id="description" name="listing[description]" placeholder="Enter description" class="form-control listing-description" required></textarea>
                    </div>
                    <div class="mb-3">
                        <label for="imageUrl" class="form-label">Image URL</label>
                        <input type="text" id="imageUrl" name="listing[image][url]" placeholder="Enter image URL" class="form-control">
                    </div>
                    <div class="row g-3">
                        <div class="mb-3 col-md-4">
                            <label for="price" class="form-label">Price</label>
                            <input type="number" id="price" name="listing[price]" step="0.01" placeholder="Enter price" class="form-control" required>
                        </div>
                        <div class="mb-3 col-md-8">
                            <label for="country" class="form-label">Country</label>
                            <input type="text" id="country" name="listing[country]" placeholder="Enter country" class="form-control" required>
                        </div>
                    </div>
                    <div class="mb-3">
                        <label for="location" class="form-label">Location</label>
                        <input type="text" id="location" name="listing[location]" placeholder="Enter location" class="form-control" required>
                    </div>

                    <div class="listing-form-actions">
                        <button type="submit" class="btn btn-dark add-btn listing-submit-btn">Create Listing</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</section>
