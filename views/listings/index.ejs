<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Wander Lust</title>
</head>
<body>
    <h1>All Listings</h1>

    <ul>
        <% allListings.forEach(listing => { %>
            <li>
                <h2><%= listing.title %></h2>
                <p><%= listing.description %></p>
                <p>Location: <%= listing.location %>, Country: <%= listing.country %></p>
                <p>Price: $<%= listing.price %></p>
                <% if (listing.image) { %>
                    <img src="<%= listing.image.url %>" alt="<%= listing.title %>" style="max-width: 200px;">
                <% } %>
                <a href="/listings/<%= listing._id %>">View Details</a>
            </li>
        <% }); %>
</body>
</html>